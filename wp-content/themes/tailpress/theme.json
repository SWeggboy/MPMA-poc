{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "1120px",
      "wideSize": "1440px"
    },
    "color": {
      "palette": [
        {
          "name": "Primary",
          "slug": "primary",
          "color": "#2E5E47"
        },
        {
          "name": "Secondary",
          "slug": "secondary",
          "color": "#53896F"
        },
        {
          "name": "Tertiary",
          "slug": "tertiary",
          "color": "#20833A"
        },
        {
          "name": "Quaternary",
          "slug": "quaternary",
          "color": "#1c4e36"
        },
        {
          "name": "Accent",
          "slug": "accent",
          "color": "#020048"
        },
        { 
          "name": "Accent Light",
          "slug": "accent-light",
          "color": "#0096FF"
        },
        {          
          "name": "Accent Dark",
          "slug": "accent-dark",
          "color": "#010047"
        },
        {
          "name": "Dark",
          "slug": "dark",
          "color": "#18181C"
        },
        {
          "name": "Light",
          "slug": "light",
          "color": "#F6F6F6"
        },
        {
          "name": "Gray",
          "slug": "gray",
          "color": "#68737c"
        }
      ]
    },
    "typography": {
      "lineHeight": true,
      "fontWeight": true,
      "fontFamilies": [
        {
          "name": "Montserrat",
          "slug": "montserrat",
          "fontFamily": "Montserrat, sans-serif"
        },
        {
          "name": "Roboto",
          "slug": "roboto",
          "fontFamily": "Roboto, sans-serif"
        },
        {
          "name": "Poppins",
          "slug": "poppins",
          "fontFamily": "Poppins, sans-serif"
        },
        {
          "name": "Roboto Slab",
          "slug": "roboto-slab",
          "fontFamily": "\"Roboto Slab\", serif"
        }
      ],
      "fontSizes": [
        {
          "name": "Extra Small",
          "slug": "xs",
          "size": "0.75rem"
        },
        {
          "name": "Small",
          "slug": "sm",
          "size": "0.875rem"
        },
        {
          "name": "Base",
          "slug": "base",
          "size": "1rem"
        },
        {
          "name": "Large",
          "slug": "lg",
          "size": "1.125rem"
        },
        {
          "name": "Extra Large",
          "slug": "xl",
          "size": "1.25rem"
        },
        {
          "name": "2XL",
          "slug": "2xl",
          "size": "1.5rem"
        },
        {
          "name": "3XL",
          "slug": "3xl",
          "size": "1.875rem"
        },
        {
          "name": "4XL",
          "slug": "4xl",
          "size": "2.5em"
        },
        {
          "name": "5XL",
          "slug": "5xl",
          "size": "3rem"
        },
        {
          "name": "6XL",
          "slug": "6xl",
          "size": "3.75rem"
        },
        {
          "name": "7XL",
          "slug": "7xl",
          "size": "4.5rem"
        },
        {
          "name": "8XL",
          "slug": "8xl",
          "size": "6rem"
        },
        {
          "name": "9XL",
          "slug": "9xl",
          "size": "8rem"
        }
      ]
    },
    "spacing": {
      "margin": true,
      "padding": true,
      "units": [
        "px",
        "rem",
        "em",
        "%",
        "vw",
        "vh"
      ],
      "spacingSizes": [
        {
            "name": "1",
            "size": "1rem",
            "slug": "10"
        },
        {
            "name": "2",
            "size": "min(1.5rem, 2vw)",
            "slug": "20"
        },
        {
            "name": "3",
            "size": "min(2.5rem, 3vw)",
            "slug": "30"
        },
        {
            "name": "4",
            "size": "min(4rem, 5vw)",
            "slug": "40"
        },
        {
            "name": "5",
            "size": "min(6.5rem, 8vw)",
            "slug": "50"
        },
        {
            "name": "6",
            "size": "min(10.5rem, 13vw)",
            "slug": "60"
        }
    ]
    },
    "blocks": {
      "core/heading": {
        "typography": {
          "lineHeight": true,
          "fontWeight": true
        },
        "spacing": {
          "margin": [
            "top",
            "right",
            "bottom",
            "left"
          ],
          "padding": [
            "top",
            "right",
            "bottom",
            "left"
          ]
        }
      },
      "core/paragraph": {
        "typography": {
          "lineHeight": true,
          "fontWeight": true
        },
        "spacing": {
          "margin": [
            "top",
            "right",
            "bottom",
            "left"
          ],
          "padding": [
            "top",
            "right",
            "bottom",
            "left"
          ]
        }
      }
    }
  },
  "styles": {
    "typography": {
      "fontFamily": "Roboto, sans-serif"
    },
    "elements": {
      "paragraph": {
        "color": {
          "text": "var(--wp--preset--color--dark)"
        },
        "typography": {
          "fontFamily": "Roboto, sans-serif",
          "fontSize": "1.125rem"
        }
      },
      "h2": {
        "color": {
          "text": "#367557"
        },
        "typography": {
          "fontFamily": "Montserrat, sans-serif",
          "fontWeight": "600",
          "fontSize": "1.75rem",
          "lineHeight": "1.1"
        }
      }
    },
    "blocks": {
      "core/heading": {
        "spacing": {
          "margin": {
            "bottom": "1.5rem"
          },
          "padding": {
            "top": "0rem",
            "right": "0rem",
            "bottom": "0rem",
            "left": "0rem"
          }
        },
        "typography": {
          "fontWeight": "600",
          "fontStyle": "normal",
          "lineHeight": "1.1"
        }
      },
      "core/paragraph": {
        "spacing": {
          "margin": {
            "bottom": "1.5rem"
          },
          "padding": {
            "top": "0rem",
            "right": "0rem",
            "bottom": "0rem",
            "left": "0rem"
          }
        },
        "typography": {
          "fontWeight": "400",
          "fontStyle": "normal",
          "lineHeight": "1.6"
        }
      },
      "core/button": {
        "border": {
          "radius": "0.375rem",
          "color": "transparent",
          "width": "0rem"
        },
        "color": {
          "background": "linear-gradient(90deg, #639c7e 0%, #408b78 50%, #138078 100%)",
          "text": "#ffffff"
        },
        "spacing": {
          "padding": {
            "top": "1rem",
            "right": "2rem",
            "bottom": "1rem",
            "left": "2rem"
          }
        },
        "typography": {
          "fontWeight": "600",
          "fontFamily": "Montserrat, sans-serif",
          "fontSize": "1rem",
          "textTransform": "uppercase"
        }
      }
    }
  }
}
